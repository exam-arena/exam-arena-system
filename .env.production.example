# Backend
DATABASE_URL=postgresql://user:password@production-db-host:5432/examarena?sslmode=require
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=https://examarena.id.vn
COOKIE_SECURE=true
COOKIE_DOMAIN=.examarena.id.vn

# Backend connection pool
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=40

# Auth and beta login policy
GET_ME_DB_TIMEOUT_MS=800
REGISTER_DB_TIMEOUT_MS=1200
REGISTER_HASH_WAIT_TIMEOUT_MS=3000
LOGIN_DB_TIMEOUT_MS=800
LOGIN_PASSWORD_WAIT_TIMEOUT_MS=3000
AUTH_PASSWORD_WORK_MAX_CONCURRENCY=0
LOGIN_IDENTIFIER_FAILURE_THRESHOLD=5
LOGIN_IDENTIFIER_COOLDOWN_SECONDS=10
REGISTER_IDENTIFIER_FAILURE_THRESHOLD=3
REGISTER_IDENTIFIER_COOLDOWN_SECONDS=15

# Rate limits. Raise LOGIN_* temporarily if a real exam room shares one public IP.
LOGIN_RATE_LIMIT_RPS=3
LOGIN_RATE_LIMIT_BURST=10
REGISTER_RATE_LIMIT_RPS=2
REGISTER_RATE_LIMIT_BURST=6
REGISTER_EMAIL_RATE_LIMIT_RPS=1
REGISTER_EMAIL_RATE_LIMIT_BURST=4
REGISTER_USERNAME_RATE_LIMIT_RPS=1
REGISTER_USERNAME_RATE_LIMIT_BURST=4
LOGIN_IDENTIFIER_RATE_LIMIT_RPS=1
LOGIN_IDENTIFIER_RATE_LIMIT_BURST=5
START_ATTEMPT_RATE_LIMIT_RPS=1.5
START_ATTEMPT_RATE_LIMIT_BURST=5
SUBMIT_ATTEMPT_RATE_LIMIT_RPS=1
SUBMIT_ATTEMPT_RATE_LIMIT_BURST=3
GET_ATTEMPT_RATE_LIMIT_RPS=4
GET_ATTEMPT_RATE_LIMIT_BURST=12
SAVE_ANSWERS_RATE_LIMIT_RPS=8
SAVE_ANSWERS_RATE_LIMIT_BURST=20
RESULT_ATTEMPT_RATE_LIMIT_RPS=3
RESULT_ATTEMPT_RATE_LIMIT_BURST=8
REVIEW_ATTEMPT_RATE_LIMIT_RPS=2
REVIEW_ATTEMPT_RATE_LIMIT_BURST=6
GET_ATTEMPT_HISTORY_RATE_LIMIT_RPS=6
GET_ATTEMPT_HISTORY_RATE_LIMIT_BURST=18
GET_EXAM_RATE_LIMIT_RPS=10
GET_EXAM_RATE_LIMIT_BURST=30
GET_EXAMS_RATE_LIMIT_RPS=20
GET_EXAMS_RATE_LIMIT_BURST=80
GET_LATEST_EXAMS_RATE_LIMIT_RPS=20
GET_LATEST_EXAMS_RATE_LIMIT_BURST=80
GET_ROOMS_RATE_LIMIT_RPS=20
GET_ROOMS_RATE_LIMIT_BURST=80
GET_HOT_ROOMS_RATE_LIMIT_RPS=20
GET_HOT_ROOMS_RATE_LIMIT_BURST=80
GET_ROOM_EXAMS_RATE_LIMIT_RPS=20
GET_ROOM_EXAMS_RATE_LIMIT_BURST=80
JOIN_ROOM_RATE_LIMIT_RPS=3
JOIN_ROOM_RATE_LIMIT_BURST=10
GET_PROFILE_RATE_LIMIT_RPS=10
GET_PROFILE_RATE_LIMIT_BURST=30
UPDATE_PROFILE_RATE_LIMIT_RPS=3
UPDATE_PROFILE_RATE_LIMIT_BURST=10

# Attempt workers
START_ATTEMPT_DB_TIMEOUT_MS=800
SUBMIT_WORKER_TIMEOUT_MS=5000
ATTEMPT_ANSWER_FLUSH_INTERVAL_SECONDS=15
ATTEMPT_ANSWER_FLUSH_BATCH_SIZE=100
ATTEMPT_AUTO_SUBMIT_SWEEP_INTERVAL_SECONDS=30
ATTEMPT_AUTO_SUBMIT_SWEEP_BATCH_SIZE=100

# Cloudinary is only for avatars during beta.
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
CLOUDINARY_AVATAR_FOLDER=exam-arena/production/avatars

# Frontend
NEXT_PUBLIC_API_URL=https://api.examarena.id.vn
API_INTERNAL_URL=http://backend:8080
